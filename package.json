{
    "name": "@diia-inhouse/diia-metrics",
    "version": "6.5.13",
    "description": "package to export prometheus metrics",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-diia-metrics",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "build-watch": "tsc --watch",
        "prepare": "ts-patch install -s && npm run build",
        "semantic-release": "semantic-release",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint . --fix && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "resolutions": {
        "@babel/traverse": "7.23.2"
    },
    "dependencies": {
        "prom-client": "15.1.3"
    },
    "peerDependencies": {
        "@diia-inhouse/errors": ">=1.10.0",
        "@diia-inhouse/types": ">=6.30.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/diia-logger": "3.19.4",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/test": "7.3.12",
        "@types/node": "25.3.3",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "eslint": "9.36.0",
        "eslint-plugin-prettier": "5.5.4",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "nock": "14.0.10",
        "prettier": "3.6.2",
        "rimraf": "6.0.1",
        "semantic-release": "24.2.9",
        "type-fest": "5.0.1",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
