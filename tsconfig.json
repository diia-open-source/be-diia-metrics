{
    "extends": "@diia-inhouse/configs/tsconfig",
    "compilerOptions": {
        "outDir": "dist",
        "declarationDir": "dist/types",
        "isolatedDeclarations": true,
        "paths": {
            "@services/*": ["./src/services/*"],
            "@interfaces/*": ["./src/interfaces/*"],
            "@src/*": ["./src/*"],
            "@tests/*": ["./tests/*"]
        },
        "strict": true,
        "skipLibCheck": true,
        "rootDir": "./src"
    },
    "include": ["src/**/*"]
}
