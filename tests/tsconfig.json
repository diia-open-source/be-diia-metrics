{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "baseUrl": "../",
        "types": ["vite/client", "vitest/globals", "node"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "isolatedModules": true,
        "paths": {
            "@services/*": ["src/services/*"],
            "@interfaces/*": ["src/interfaces/*"],
            "@src/*": ["src/*"],
            "@tests/*": ["tests/*"]
        },
        "noEmit": true,
        "strict": true
    },
    "include": ["./**/*", "../vitest.config.mts"]
}
