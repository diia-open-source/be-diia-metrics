{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "types": ["vite/client", "vitest/globals", "node"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "isolatedDeclarations": false,
        "isolatedModules": true,
        "paths": {
            "@services/*": ["../src/services/*"],
            "@interfaces/*": ["../src/interfaces/*"],
            "@src/*": ["../src/*"],
            "@tests/*": ["./*"]
        },
        "noEmit": true,
        "strict": true,
        "rootDir": "../"
    },
    "include": ["./**/*", "../vitest.config.mts"]
}
